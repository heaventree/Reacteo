# Supabase — required for AI audit and blog features
# Get these from your Supabase project: Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Site hostname — used by sitemap generator and canonical URLs
# Set to your production domain
VITE_SEO_HOSTNAME=https://yourdomain.com

# OG image — default Open Graph image for pages that don't specify one
VITE_SEO_OG_IMAGE=https://yourdomain.com/og-default.jpg

# AI provider keys — add these as Edge Function Secrets in Supabase, not here
# Supabase dashboard → Settings → Edge Functions → Secrets
# Only configure providers you intend to use. At least one is required for AI features.
#
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# CLAUDE_API_KEY=sk-ant-...
# PERPLEXITY_API_KEY=pplx-...
# DEEPSEEK_API_KEY=sk-...
