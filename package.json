{
  "name": "reacteo",
  "version": "2.0.0",
  "description": "Production-ready SEO library for React with server-side meta injection, client-side live sync, AI-powered content generation, and comprehensive admin tools. Battle-tested at niimo.io.",
  "private": false,
  "type": "module",
  "main": "./dist/lib/index.cjs",
  "module": "./dist/lib/index.js",
  "types": "./dist/lib/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/lib/index.js",
      "require": "./dist/lib/index.cjs",
      "types": "./dist/lib/index.d.ts"
    },
    "./plugin": {
      "import": "./dist/lib/seo/reactseo-plugin/index.js",
      "types": "./dist/lib/seo/reactseo-plugin/index.d.ts"
    }
  },
  "files": [
    "dist/lib",
    "README.md",
    "INSTALLATION.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "react",
    "seo",
    "meta-tags",
    "open-graph",
    "twitter-cards",
    "structured-data",
    "schema-org",
    "json-ld",
    "sitemap",
    "robots-txt",
    "ai",
    "openai",
    "claude",
    "gemini",
    "typescript",
    "supabase",
    "server-side-rendering",
    "ssr",
    "crawler",
    "social-sharing",
    "metadata",
    "react-helmet",
    "indexnow",
    "google-search-console",
    "production",
    "battle-tested"
  ],
  "author": "Sean O'Byrne <sean@heaventree.co> (https://heaventree.co)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/heaventree-ltd/reacteo.git"
  },
  "bugs": {
    "url": "https://github.com/heaventree-ltd/reacteo/issues"
  },
  "homepage": "https://github.com/heaventree-ltd/reacteo#readme",
  "engines": {
    "node": ">=16.13.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node scripts/generate-sitemap.js && node scripts/generate-robots.js",
    "build:lib": "vite build --config vite.lib.config.ts",
    "seo:audit": "node scripts/seo-audit.js",
    "seo:audit:pre-deploy": "npm run build && npm run seo:audit",
    "lint": "eslint .",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.app.json"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-dom": ">=17.0.0",
    "react-helmet-async": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "react-helmet-async": {
      "optional": false
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.57.4",
    "lucide-react": "^0.344.0",
    "react-helmet-async": "^3.0.0",
    "sitemap": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.18",
    "eslint": "^9.9.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "globals": "^15.9.0",
    "postcss": "^8.4.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.1",
    "terser": "^5.46.0",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.3.0",
    "vite": "^5.4.2"
  }
}
